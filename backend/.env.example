# .env.example
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit the real .env file to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# Leave commented out to use SQLite locally (zero config).
# Uncomment and fill in for PostgreSQL:
# DATABASE_URL=postgresql://taskuser:taskpass@localhost:5432/taskdb

# ── CORS ──────────────────────────────────────────────────────────────────────
# Use * for development. Set your domain(s) in production:
# ALLOWED_ORIGINS=https://myapp.com,https://staging.myapp.com
ALLOWED_ORIGINS=*

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ── Server port ───────────────────────────────────────────────────────────────
# Local: 8000 | Render: 10000
PORT=8000
